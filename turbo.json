{
    "$schema": "https://turbo.build/schema.json",
    "pipeline": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": ["dist"],
            "inputs": ["scr/**/*", "package.json", "README.md", "tsconfig.json"]
        },
        "flush": {
            "inputs": ["dist"]
        }
    }
}