{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": ["dist/**"],
            "inputs": ["scr/**/*", "package.json", "README.md", "tsconfig.json"]
        },
        "vortexus.js#build": {
            "dependsOn": ["@vortexus.js/core#build"]
        },
        "flush": {
            "inputs": ["dist/**"]
        }
    }
}